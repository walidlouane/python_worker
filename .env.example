# Copy to .env before: docker compose up -d

# Platform RabbitMQ on host (Docker Desktop + opportunities-scanner compose)
RABBITMQ_URL=amqp://mgce:YOUR_PASSWORD@host.docker.internal:5672/mgce

WORKER_ID=scrapy-worker-docker-1
ADD_COMPANY_QUEUE=add_company
SCRAPER_REGISTER_QUEUE=scraper.register
URL_TO_CRAWL_QUEUE=url_to_crawl
DEFAULT_SOURCE=charika
DEFAULT_COUNTRY=Morocco
